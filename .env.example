# Supabase (contact form archive in DB — see supabase/migrations/001_contact_messages.sql)
NEXT_PUBLIC_SUPABASE_URL=https://alewbsbnkwgabewzowfv.supabase.co
# Dashboard publishable key (sb_publishable_…), if you use newer Supabase client helpers
